generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  CASHIER
}

enum BillStatus {
  OPEN
  SUBMITTED
  CANCELLED
}

enum BranchType {
  PERMANENT
  TEMPORARY
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  active    Boolean  @default(true)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bills     Bill[]
}

model Branch {
  id                String     @id @default(cuid())
  name              String
  code              String     @unique
  address           String?
  phone             String?
  pincode           String?    @unique
  type              BranchType @default(PERMANENT)
  reportBranchId    String?
  bigsellerBranchId String?
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  users             User[]
  bills             Bill[]
}

model Item {
  id           String     @id @default(cuid())
  sku          String     @unique
  barcode      String     @unique
  name         String
  description  String?
  imageUrl     String?
  defaultPrice Decimal    @db.Decimal(10, 2)
  category     String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  billItems    BillItem[]
}

model Bill {
  id          String     @id @default(cuid())
  billNumber  String     @unique
  branchId    String
  branch      Branch     @relation(fields: [branchId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  status      BillStatus @default(OPEN)
  source      String     @default("POS")    // "POS" | "IMPORT"
  saleDate    DateTime?                      // original sale date for imported records
  subtotal    Decimal    @db.Decimal(10, 2) @default(0)
  discount    Decimal    @db.Decimal(10, 2) @default(0)
  total       Decimal    @db.Decimal(10, 2) @default(0)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  submittedAt DateTime?
  items       BillItem[]
}

model BillItem {
  id       String  @id @default(cuid())
  billId   String
  bill     Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item    @relation(fields: [itemId], references: [id])
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)
  discount Decimal @db.Decimal(10, 2) @default(0)
  subtotal Decimal @db.Decimal(10, 2)
}

model ReportTemplate {
  id               String   @id @default(cuid())
  name             String
  description      String?
  // Column header names as they appear in the Excel file
  columnDate       String?
  columnBarcode    String?
  columnSku        String?
  columnPrice      String   @default("Price")
  columnQty        String   @default("Qty")
  columnBranchId   String?
  columnBranchName String?
  // How to match branches: "name" | "code" | "reportBranchId" | "bigsellerBranchId"
  branchMatchBy    String   @default("name")
  // How to match items: "barcode" | "sku"
  itemMatchBy      String   @default("barcode")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
