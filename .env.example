# Database password (required)
DB_PASSWORD=replace-with-strong-random-password

# JWT Secret — minimum 64 random characters (required)
# Generate: openssl rand -hex 64
JWT_SECRET=replace-with-64-char-random-hex-string

# Frontend URL for CORS (required) — no trailing slash
FRONTEND_URL=https://your-domain.com

# Port to expose nginx on the host (default 8082)
PORT=8082

# Image tag used by Docker Compose.
# CI/CD rewrites this on the server during deployment.
IMAGE_TAG=local-dev

# Cloudflare Tunnel Token (from Zero Trust dashboard)
TUNNEL_TOKEN=your_cloudflare_tunnel_token
