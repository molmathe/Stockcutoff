generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  CASHIER
}

enum BillStatus {
  OPEN
  SUBMITTED
  CANCELLED
}

enum BranchType {
  PERMANENT
  TEMPORARY
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  active    Boolean  @default(true)
  isSystem  Boolean  @default(false)
  createdAt    DateTime       @default(now())
  updatedAt      DateTime         @updatedAt
  bills          Bill[]
  importDrafts   ImportDraft[]
  unresolvedSales UnresolvedSale[]
  auditLogs      AuditLog[]

  @@index([branchId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action])
}

model Branch {
  id                String     @id @default(cuid())
  name              String
  code              String     @unique
  address           String?
  phone             String?
  pincode           String?    @unique
  type              BranchType @default(PERMANENT)
  reportBranchId    String?
  tags              String[]   @default([])
  active            Boolean    @default(true)
  deletedAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  users             User[]
  bills             Bill[]
  targets           BranchTarget[]

  @@index([deletedAt])
}

model Item {
  id           String     @id @default(cuid())
  sku          String
  barcode      String     @unique
  name         String
  description  String?
  imageUrl     String?
  defaultPrice Decimal    @db.Decimal(10, 2)
  category     String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  saleDate     DateTime?
  billItems    BillItem[]

  @@index([sku])
  @@index([category, active])
  @@index([active])
  @@index([name])
}

model Bill {
  id          String     @id @default(cuid())
  billNumber  String     @unique
  branchId    String
  branch      Branch     @relation(fields: [branchId], references: [id])
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  status      BillStatus @default(OPEN)
  source      String     @default("POS")    // "POS" | "IMPORT"
  importPlatform String?                     // "CENTRAL" | "MBK" | "PLAYHOUSE"
  saleDate    DateTime?                      // original sale date for imported records
  subtotal    Decimal    @db.Decimal(10, 2) @default(0)
  discount    Decimal    @db.Decimal(10, 2) @default(0)
  discountPct Decimal    @db.Decimal(5, 2)  @default(0)
  total       Decimal    @db.Decimal(10, 2) @default(0)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  submittedAt DateTime?
  items       BillItem[]

  @@index([userId])
  @@index([branchId, status, createdAt])
  @@index([status, createdAt])
  @@index([saleDate])
}

model BillItem {
  id             String  @id @default(cuid())
  billId         String
  bill           Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item    @relation(fields: [itemId], references: [id])
  quantity       Int     @default(1)
  price          Decimal @db.Decimal(10, 2)
  discount       Decimal @db.Decimal(10, 2) @default(0)  // Manual per-line discount
  globalDiscount Decimal @db.Decimal(10, 2) @default(0)  // Pro-rata share of global bill discount
  subtotal       Decimal @db.Decimal(10, 2)               // price*qty - discount - globalDiscount (net)

  @@index([billId])
  @@index([itemId])
}

model ImportDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  platform  String
  fileName  String
  rowsData  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BlockedBarcode {
  id        String   @id @default(cuid())
  barcode   String   @unique
  reason    String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barcode])
}

model UnresolvedSale {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  platform     String
  fileName     String
  
  saleDate     String?
  rawDate      String?
  rawBranch    String?
  rawItem      String?
  qty          Int
  price        Decimal   @db.Decimal(10,2)
  
  status       String    @default("PENDING")
  errors       Json
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([userId])
}

model BranchTarget {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  year      Int
  month     Int
  target    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, year, month])
  @@index([year, month])
}
